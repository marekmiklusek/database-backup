{
    "name": "marekmiklusek/laravel-database-backup",
    "description": "A Laravel package for backing up MySQL databases, with support for storing backups locally, on Google Drive, or both.",
    "version": "v1.0.1",
    "license": "MIT",
    "authors": [
        {
            "name": "Marek Miklusek",
            "email": "marek.miklusek@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.31"
    },
    "autoload": {
        "psr-4": {
            "MarekMiklusek\\LaravelDatabaseBackup\\": "src"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MarekMiklusek\\LaravelDatabaseBackup\\DatabaseBackupServiceProvider"
            ]
        }
    }
}
