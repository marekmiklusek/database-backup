    "keywords": ["laravel", "database", "backup"],
    "license": "MIT",
    "authors": [
        {
            "name": "Marek Miklusek",
            "email": "marek.miklusek@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "require": {
